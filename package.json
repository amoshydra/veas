{
  "name": "veas",
  "private": true,
  "scripts": {
    "dev:server": "pnpm --filter @veas/server dev",
    "dev:client": "pnpm --filter @veas/client dev",
    "dev": "concurrently \"pnpm dev:server\" \"pnpm dev:client\"",
    "build": "pnpm -r build",
    "db:generate": "pnpm --filter @veas/server db:generate",
    "db:migrate": "pnpm --filter @veas/server db:migrate",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:fix": "oxfmt --write"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "lefthook": "^1.11.0",
    "msw": "^2.12.14",
    "oxfmt": "^0.19.0",
    "oxlint": "^1.0.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "lefthook",
      "msw"
    ]
  }
}
